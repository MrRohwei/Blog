# ─────────────────────────────────────────────
#  Voidpen · 环境变量配置
#  复制本文件为 .env，填写真实值后启动
#  注意：.env 不要提交到 Git！
# ─────────────────────────────────────────────

# ── MySQL ──────────────────────────────────
MYSQL_ROOT_PASSWORD=Root@123456
MYSQL_DATABASE=voidpen
MYSQL_USER=voidpen
MYSQL_PASSWORD=Voidpen@123456

# ── Redis ──────────────────────────────────
REDIS_PASSWORD=Redis@123456

# ── JWT ────────────────────────────────────
# 至少 32 位字符，生产环境务必替换！
JWT_SECRET=voidpen-local-dev-secret-key-change-in-prod

# ── OSS 对象存储（本地开发可留空，图片上传功能不可用）──
OSS_KEY_ID=
OSS_KEY_SECRET=
OSS_ENDPOINT=
OSS_BUCKET=
